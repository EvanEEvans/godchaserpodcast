# --- Public URLs ---------------------------------------------------------

NEXT_PUBLIC_SITE_URL=https://godchaserpodcast.com
NEXT_PUBLIC_BSP_URL=https://bible.godchaserpodcast.com

# --- Brevo (transactional + lists) ---------------------------------------
# Get the API key from Brevo dashboard → SMTP & API → API Keys.

BREVO_API_KEY=

# Numeric Brevo list IDs. Create two lists in Brevo first
# (e.g. "Godchaser — Newsletter" and "Godchaser — Contact"),
# then paste their numeric IDs here.

BREVO_NEWSLETTER_LIST_ID=
BREVO_CONTACT_LIST_ID=

# --- Contact form delivery ----------------------------------------------
# Where contact form submissions are emailed to.

CONTACT_INBOX_EMAIL=evan@coursecreatorplus.com

# Verified sender address in Brevo. Must be a domain you've authenticated
# (SPF + DKIM) in Brevo, e.g. noreply@godchaserpodcast.com once DNS is set.

CONTACT_FROM_EMAIL=noreply@godchaserpodcast.com
